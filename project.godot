; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CSCI6562Project"
run/main_scene="res://UI/MainMenu/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[audio]

buses/default_bus_layout="uid://bwam6c5m7j3nx"

[autoload]

CycleClock="*res://Autoloads/CycleClock.gd"
FactionState="*res://Autoloads/FactionState.gd"
LevelSelection="*res://Autoloads/LevelSelection.gd"
CustomSceneTransition="*uid://bx0vhoqcb7gk5"
CustomSceneFader="*uid://bls4r1d4b76tl"
AudioManager="*uid://cr6iqlsyjuhe5"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://bdgmakrlksskw"

[editor]

version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/HexLevelEditor/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
