; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CSCI6562Project"
run/main_scene="uid://cee1l7i5l0agi"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

CycleClock="*uid://c4rt1ghrw3cqm"
FactionState="*uid://dq00uwal06v7b"
LevelSelection="*uid://cxfc6i17b7wk6"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
mouse_cursor/custom_image="uid://bdgmakrlksskw"

[editor]

version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/HexLevelEditor/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
